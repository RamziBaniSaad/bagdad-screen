<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Hero — Popcorn</title>
<link rel="stylesheet" href="styles.css">
<script src="image-slot.js"></script>
<style>
  * { box-sizing: border-box; }
  html, body { margin: 0; height: 100%; background: #000; overflow: hidden; }
  #viewport { position: fixed; inset: 0; display: flex; align-items: center; justify-content: center; }

  .stage {
    width: 1920px; height: 1080px; position: relative; overflow: hidden;
    transform-origin: center center;
    background: var(--bb-dunkelbraun, #2C2218);
    font-family: var(--font-body, 'Mulish', sans-serif);
  }

  /* ---- Layer 1 · full-bleed photo (Ken-Burns lives here) ---- */
  .photo { position: absolute; inset: 0; overflow: hidden; }
  image-slot {
    display: block; width: 100%; height: 100%;
    transform-origin: 54% 46%;
    /* While empty: a deliberate navy → dark-brown ground shows through the
       translucent slot frame, so the slide reads as intentional even unfilled. */
    background: linear-gradient(125deg,
      var(--bb-marineblau, #1B3A5C) 0%,
      var(--bb-marineblau-700, #122943) 48%,
      var(--bb-dunkelbraun, #2C2218) 100%);
  }
  /* Tint the slot's built-in empty UI to cream so the drop hint sits calmly on the dark ground */
  image-slot::part(empty) { color: rgba(245, 236, 218, 0.70); }
  image-slot::part(ring)  { border-color: rgba(245, 236, 218, 0.20); }

  /* ---- Layer 2 · scrims (darken the left copy column + seat the footer) ---- */
  .scrim { position: absolute; inset: 0; pointer-events: none; }
  .scrim-left {
    background: linear-gradient(90deg,
      rgba(27, 58, 92, 0.92) 0%,
      rgba(27, 58, 92, 0.80) 17%,
      rgba(27, 58, 92, 0.44) 37%,
      rgba(27, 58, 92, 0.00) 56%);
  }
  .scrim-bottom {
    background: linear-gradient(0deg,
      rgba(18, 28, 40, 0.66) 0%,
      rgba(18, 28, 40, 0.22) 13%,
      rgba(18, 28, 40, 0.00) 26%);
  }

  /* ---- Layer 3 · slow, wide, soft diagonal light sweep ---- */
  .sweep {
    position: absolute; top: -25%; left: 0; width: 52%; height: 150%;
    pointer-events: none;
    background: linear-gradient(105deg, transparent 0%, rgba(255, 247, 232, 0.10) 50%, transparent 100%);
    transform: translateX(-230%) skewX(-12deg);
  }

  /* ---- Layer 4 · faint warm/steam wisps over the popcorn (subtle, GPU-cheap) ---- */
  .steam {
    position: absolute; pointer-events: none; opacity: 0;
    background: radial-gradient(closest-side, rgba(255, 244, 224, 0.16), rgba(255, 244, 224, 0) 72%);
  }
  .steam.s1 { left: 51%; bottom: 30%; width: 360px; height: 360px; }
  .steam.s2 { left: 62%; bottom: 37%; width: 300px; height: 300px; }
  .steam.s3 { left: 45%; bottom: 41%; width: 280px; height: 280px; }

  /* ---- Layer 5 · corner star — discreet, calm, static (~10%) ---- */
  .corner-star {
    position: absolute; top: -200px; left: -180px;
    width: 600px; height: 600px;
    color: var(--bb-goldbraun, #E0A85E);
    opacity: 0.10; pointer-events: none;
  }
  .corner-star svg { width: 100%; height: 100%; display: block; }

  /* ---- Copy · anchored bottom-left ---- */
  .copy {
    position: absolute; left: var(--slide-pad, 110px); bottom: 236px;
    width: 880px; max-width: 52%;
    display: flex; flex-direction: column; align-items: flex-start;
  }

  .eyebrow {
    display: inline-flex; align-items: center; gap: 20px;
    color: var(--bb-goldbraun, #E0A85E);
    font-weight: 800; font-size: 34px;
    letter-spacing: 0.26em; text-transform: uppercase;
    margin: 0 0 22px;
    text-shadow: 0 2px 14px rgba(18, 12, 6, 0.45);
  }
  .eyebrow .star-sm { width: 30px; height: 30px; flex: none; }

  .headline {
    font-family: var(--font-display, 'Amiri', serif);
    font-weight: 700; font-size: 186px; line-height: 0.92;
    letter-spacing: -0.01em; text-wrap: balance;
    color: var(--bb-sandcreme, #F5ECDA);
    margin: 0;
    text-shadow: 0 6px 32px rgba(14, 9, 4, 0.52);
  }

  .subline {
    font-weight: 500; font-size: 46px; line-height: 1.28; text-wrap: pretty;
    color: rgba(245, 236, 218, 0.90);
    margin: 26px 0 0;
    text-shadow: 0 2px 16px rgba(14, 9, 4, 0.46);
  }
  .subline .mid { color: var(--bb-goldbraun, #E0A85E); padding: 0 4px; }

  /* Opening hook — the price is the loud note */
  .hook { margin-top: 48px; display: flex; align-items: flex-end; gap: 30px; }
  .hook .amt {
    display: inline-flex; align-items: baseline; gap: 18px;
    color: var(--bb-goldbraun, #E0A85E); font-weight: 800; line-height: 0.86;
    text-shadow: 0 4px 24px rgba(14, 9, 4, 0.5);
  }
  .hook .pre { font-size: 60px; }
  .hook .num { font-size: 138px; letter-spacing: -0.01em; }
  .hook .meta { display: flex; flex-direction: column; gap: 8px; padding-bottom: 16px; }
  .hook .was {
    font-size: 46px; font-weight: 700;
    color: rgba(245, 236, 218, 0.60);
    text-decoration: line-through; text-decoration-thickness: 4px;
  }
  .hook .cap {
    font-size: 26px; font-weight: 700;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: rgba(245, 236, 218, 0.72);
  }

  .fineprint {
    margin-top: 22px; font-size: 30px; font-weight: 500; letter-spacing: 0.01em;
    color: rgba(245, 236, 218, 0.66);
    text-shadow: 0 2px 12px rgba(14, 9, 4, 0.4);
  }

  /* ---- Footer · date · hours · address  +  logo on a cream field ---- */
  .footer {
    position: absolute; left: var(--slide-pad, 110px); right: var(--slide-pad, 110px); bottom: 58px;
    display: flex; align-items: center; justify-content: space-between; gap: 48px;
    pointer-events: none;
  }
  .footer .info {
    font-size: 32px; font-weight: 600; letter-spacing: 0.01em;
    color: rgba(245, 236, 218, 0.92);
    text-shadow: 0 2px 14px rgba(14, 9, 4, 0.5);
  }
  .footer .info .dot { color: var(--bb-goldbraun, #E0A85E); padding: 0 14px; }
  .logo-badge {
    flex: none; background: var(--bb-sandcreme, #F5ECDA);
    border-radius: var(--radius-md, 14px); padding: 16px 24px;
    box-shadow: var(--shadow-md, 0 8px 22px rgba(44, 34, 24, 0.16));
  }
  .logo-badge img { height: 96px; display: block; }

  /* ---- Motion · transform / opacity only · reduced-motion safe (end-state = base) ---- */
  @media (prefers-reduced-motion: no-preference) {
    /* Default (no .play) = visible base at full opacity. The staggered entrance
       moves with TRANSFORM ONLY (opacity stays 1), so a still capture or a
       non-animating frame is always legible — never a blank/0-opacity flash.
       .play is added on first paint and layers the "rise from below". */
    .stage.play .eyebrow   { animation: riseUp 0.8s cubic-bezier(.22,.61,.36,1) 0.10s both; }
    .stage.play .headline  { animation: riseUp 0.8s cubic-bezier(.22,.61,.36,1) 0.24s both; }
    .stage.play .subline   { animation: riseUp 0.8s cubic-bezier(.22,.61,.36,1) 0.38s both; }
    .stage.play .hook      { animation: riseUp 0.8s cubic-bezier(.22,.61,.36,1) 0.52s both; }
    .stage.play .fineprint { animation: riseUp 0.8s cubic-bezier(.22,.61,.36,1) 0.64s both; }
    .stage.play .footer    { animation: riseUp 0.8s cubic-bezier(.22,.61,.36,1) 0.76s both; }

    .stage.play image-slot { will-change: transform; animation: kenburns 16s ease-in-out 0.4s infinite alternate; }
    .stage.play .sweep     { will-change: transform; animation: sweep 11s ease-in-out 2.2s infinite; }
    .stage.play .steam.s1  { animation: steam 8.0s ease-in-out 1.4s infinite; }
    .stage.play .steam.s2  { animation: steam 9.6s ease-in-out 2.8s infinite; }
    .stage.play .steam.s3  { animation: steam 8.8s ease-in-out 3.6s infinite; }
  }

  @keyframes riseUp {
    from { transform: translateY(26px); }
    to   { transform: translateY(0); }
  }
  @keyframes kenburns {
    from { transform: scale(1.0)  translate(0, 0); }
    to   { transform: scale(1.08) translate(-1.4%, -1.2%); }
  }
  @keyframes sweep {
    0%   { transform: translateX(-230%) skewX(-12deg); }
    28%  { transform: translateX(360%)  skewX(-12deg); }
    100% { transform: translateX(360%)  skewX(-12deg); }
  }
  @keyframes steam {
    0%   { opacity: 0;    transform: translateY(44px)  scale(0.9); }
    35%  { opacity: 0.95; }
    72%  { opacity: 0.5;  }
    100% { opacity: 0;    transform: translateY(-130px) scale(1.2); }
  }
</style>
</head>
<body>
  <div id="viewport">
    <div class="stage" id="stage">

      <!-- 1 · full-bleed product photo -->
      <div class="photo">
        <image-slot id="hero-popcorn" shape="rect" fit="cover"
          placeholder="Popcorn-Foto hier ablegen — frisch gepoppt, warmes Licht, randvolle Tüte"></image-slot>
      </div>

      <!-- 2 · scrims -->
      <div class="scrim scrim-bottom"></div>
      <div class="scrim scrim-left"></div>

      <!-- 3 · light sweep -->
      <div class="sweep"></div>

      <!-- 4 · warm steam wisps -->
      <div class="steam s1"></div>
      <div class="steam s2"></div>
      <div class="steam s3"></div>

      <!-- 5 · corner star -->
      <div class="corner-star">
        <svg viewBox="0 0 100 100"><path d="M50 2 L57.65 31.52 L83.94 16.06 L68.48 42.35 L98 50 L68.48 57.65 L83.94 83.94 L57.65 68.48 L50 98 L42.35 68.48 L16.06 83.94 L31.52 57.65 L2 50 L31.52 42.35 L16.06 16.06 L42.35 31.52 Z" fill="currentColor"/></svg>
      </div>

      <!-- copy -->
      <div class="copy">
        <div class="eyebrow reveal">
          <svg class="star-sm" viewBox="0 0 100 100"><path d="M50 2 L57.65 31.52 L83.94 16.06 L68.48 42.35 L98 50 L68.48 57.65 L83.94 83.94 L57.65 68.48 L50 98 L42.35 68.48 L16.06 83.94 L31.52 57.65 L2 50 L31.52 42.35 L16.06 16.06 L42.35 31.52 Z" fill="currentColor"/></svg>
          Neu bei uns
        </div>
        <h1 class="headline reveal">Frisches Popcorn</h1>
        <p class="subline reveal">frisch bei uns gepoppt<span class="mid">·</span>warm &amp; salzig</p>

        <div class="hook reveal">
          <span class="amt"><span class="pre">nur</span><span class="num">10&nbsp;ct</span></span>
          <span class="meta">
            <span class="was">1&nbsp;€</span>
            <span class="cap">kleine Tüte</span>
          </span>
        </div>

        <div class="fineprint reveal">nur am Eröffnungswochenende</div>
      </div>

      <!-- footer -->
      <div class="footer reveal">
        <div class="info">Sa 27. &amp; So 28. Juni<span class="dot">·</span>6–13&nbsp;Uhr<span class="dot">·</span>Dörnbek 10, Brokstedt</div>
        <div class="logo-badge"><img src="assets/logo-full.png" alt="Bäckerei Bagdad"></div>
      </div>

    </div>
  </div>

  <script>
    (function () {
      var stage = document.getElementById('stage');
      var vp = document.getElementById('viewport');
      function fit() {
        var s = Math.min(vp.clientWidth / 1920, vp.clientHeight / 1080);
        stage.style.transform = 'scale(' + s + ')';
      }
      window.addEventListener('resize', fit);
      fit();
      // kick off the staggered entrance once layout has settled
      requestAnimationFrame(function () {
        requestAnimationFrame(function () { stage.classList.add('play'); });
      });
    })();
  </script>
</body>
</html>
